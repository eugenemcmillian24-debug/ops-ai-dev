import { db } from './db';
import { users } from './db';
import Stripe from 'stripe';

const stripe = new Stripe(process.env.STRIPE_SECRET_KEY!);

export async function predictCost(action: string): Promise<number> {
  const costs = {
    'agentRun': 2000,
    'terminalMessage': 50,
    'deployment': 1000,
    'webcontainerMinute': 50,
    // Add all from your table
  };
  return costs[action as keyof typeof costs] || 100;
}

export async function deductCredits(userId: number, amount: number) {
  const user = await db.update(users).set({ credits: sql`${users.credits} - ${amount}` }).where(eq(users.id, userId)).returning();
  return user[0]?.credits ?? 0 >= 0;
}

export async function buyCredits(userId: number, pack: '1k' | '5k' | '10k') {
  const amounts = { '1k': 1000, '5k': 5000, '10k': 10000 };
  const session = await stripe.checkout.sessions.create({
    mode: 'payment',
    line_items: [{ price_data: { currency: 'usd', product_data: { name: `${pack} credits` }, unit_amount: amounts[pack] * 10 }, quantity: 1 }],
    success_url: `${process.env.NEXTAUTH_URL}/?success=true`,
    cancel_url: `${process.env.NEXTAUTH_URL}/?cancel=true`,
    metadata: { userId: userId.toString() },
  });
  // Webhook will add credits on success
  return session.url;
}
```
Every action (AI run, deploy, etc.) calls `if (!await deductCredits(session.user.id, await predictCost(action))) throw new Error('Insufficient credits');`[5][6]


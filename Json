{
  "name": "CodeCraft AI MVP",
  "version": "1.0.0",
  "description": "Production-ready AI Dev Platform - Pure Pay-Per-Use (NO FREE TIER)",
  "framework": "nextjs",
  "template": "app",
  "typescript": true,
  "tailwind": true,
  "srcDir": true,
  "appDir": true,
  "importAlias": "@/*",
  "nextjsVersion": "15",
  "production": true,
  "deployPlatform": "vercel",
  "monetization": "pure_pay_per_use",
  
  "env": {
    "required": [
      "DATABASE_URL",
      "STRIPE_SECRET_KEY", 
      "GROQ_API_KEY",
      "OPENROUTER_API_KEY",
      "GITHUB_ID",
      "GITHUB_SECRET",
      "NEXTAUTH_SECRET",
      "NEXTAUTH_URL",
      "STRIPE_WEBHOOK_SECRET"
    ]
  },
  
  "dependencies": {
    "core": ["next", "typescript", "react", "react-dom"],
    "ui": ["tailwindcss", "class-variance-authority", "tailwind-merge", "lucide-react"],
    "auth": ["next-auth@beta"],
    "db": ["drizzle-orm", "@neondatabase/serverless", "drizzle-kit", "pg"],
    "ai": ["@ai-sdk/groq", "@ai-sdk/openai", "langgraph", "@langchain/core", "zod"],
    "payments": ["stripe"],
    "preview": ["@webcontainer/api", "@monaco-editor/react", "@codesandbox/sandpack-react"],
    "utils": ["jszip", "file-saver", "@octokit/rest", "framer-motion", "cmdk", "reactflow", "@supabase/supabase-js", "@upstash/redis"],
    "shadcn": ["button", "dialog", "card", "badge", "avatar", "dropdown-menu"]
  },
  
  "pricing": {
    "credits": {
      "packs": {
        "1k": {"credits": 1000, "price": 10},
        "5k": {"credits": 5000, "price": 45},
        "10k": {"credits": 10000, "price": 85},
        "50k": {"credits": 50000, "price": 375},
        "100k": {"credits": 100000, "price": 650}
      },
      "actions": {
        "terminalMessage": 50,
        "agentRun": 2000,
        "webcontainerMinute": 50,
        "deployment": 1000,
        "mobileExport": 900,
        "securityScan": 1500
      }
    }
  },
  
  "ai": {
    "primary": "llama-3.1-70b-versatile",
    "speed": "llama-3.1-8b-instant", 
    "fallback": "qwen/qwen3-coder:free",
    "voice": "distil-whisper-large-v3-en",
    "providers": ["groq", "openrouter"]
  },
  
  "fileStructure": {
    "lib": [
      "db.ts",
      "credits.ts", 
      "auth.ts",
      "codecraft-graph.ts"
    ],
    "app/api": {
      "auth/[...nextauth]": "route.ts",
      "credits/buy": "route.ts",
      "credits/deduct": "route.ts",
      "stripe/webhook": "route.ts"
    },
    "app": [
      "ai-terminal/page.tsx",
      "layout.tsx",
      "page.tsx"
    ],
    "components": [
      "credit-wallet.tsx",
      "webcontainer-preview.tsx", 
      "agent-status.tsx",
      "usage-forecast.tsx"
    ]
  },
  
  "schema": {
    "users": {
      "id": "serial primaryKey",
      "githubId": "text unique",
      "email": "text", 
      "credits": "integer default 0",
      "createdAt": "timestamp defaultNow"
    },
    "transactions": {
      "id": "serial primaryKey",
      "userId": "integer references users",
      "credits": "integer",
      "stripeSessionId": "text"
    }
  },
  
  "criticalFunctions": {
    "predictCost": "Returns credits needed for action",
    "deductCredits": "DB update credits -= amount, return success",
    "buyCredits": "Stripe checkout session → webhook adds credits",
    "payGate": "Every button: predict→deduct→run OR buy modal"
  },
  
  "middleware": {
    "authGuard": "Redirect unauth to /",
    "rateLimit": "Upstash Redis"
  },
  
  "pages": {
    "root": "Auth wall → Buy credits → Dashboard",
    "ai-terminal": "Pay-gated chat + WebContainer preview",
    "dashboard": "Credits balance + usage forecast"
  },
  
  "buildCommands": [
    "npx create-next-app@15 codecraft-ai --ts --eslint --tailwind --app --src-dir",
    "npx shadcn-ui@latest init",
    "npx shadcn-ui@latest add button dialog card badge avatar dropdown-menu",
    "pnpm i [all deps]",
    "npx drizzle-kit generate:pg",
    "npx drizzle-kit push:pg",
    "vercel --prod"
  ],
  
  "deploy": {
    "platform": "vercel",
    "runtime": "edge",
    "env": "all required keys",
    "domain": "codecraft-ai.vercel.app"
  },
  
  "guardrails": {
    "noFreeTier": true,
    "hardPayGates": true,
    "zeroCreditsModal": true,
    "preDeduct": true
  },
  
  "userFlow": [
    "GitHub Login",
    "Credit Wallet (0cr) → Buy $10 pack", 
    "AI Terminal → Send (50cr)",
    "WebContainer boots → Live preview",
    "Deploy → GitHub+Vercel (1000cr)"
  ],
  
  "revenueModel": "pure_pay_per_use",
  "mrrPotential": "50k",
  "shipDate": "2026-03-06"
}
